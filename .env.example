# Generate a random 32+ character secret for auth encryption
BETTER_AUTH_SECRET=

# Base URL for Better Auth (used for OAuth callbacks)
BETTER_AUTH_URL=http://localhost:5173

# Google OAuth credentials (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth credentials (optional)
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
