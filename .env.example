# =============================================
# .env — Shared secrets (gitignored, all environments)
# =============================================

# Generate a random 32+ character secret for auth encryption
BETTER_AUTH_SECRET=

# Google OAuth credentials (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth credentials (optional)
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=

# =============================================
# .env.development — Dev config (committed)
# =============================================
# BETTER_AUTH_URL=http://localhost:5173
# PORT=3001

# =============================================
# .env.production — Prod config (gitignored)
# =============================================
# BETTER_AUTH_URL=https://your-production-domain.com
# PORT=3001
